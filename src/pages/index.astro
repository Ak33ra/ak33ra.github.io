---
import BaseLayout from '../layouts/BaseLayout.astro';
import FluidHero from '../components/FluidHero.astro';
import MixedFeed from '../components/MixedFeed.astro';
import { Image } from 'astro:assets';
import headshot from '../assets/IMG_5265.jpeg';

const page_title = 'Akira van de Groenendaal';
---
<BaseLayout page_title={page_title} wide no_title og_image="/og.png">
  <FluidHero variant="lantern">
    <h1 class="hero-name">Akira van de Groenendaal</h1>
    <p class="hero-tagline">Computer Science at Carnegie Mellon University</p>
  </FluidHero>

  <section class="intro" aria-label="Introduction">
    <Image
      src={headshot}
      alt="Portrait of Akira van de Groenendaal"
      width={320}
      class="intro__portrait"
      loading="eager"
    />
    <p>
    Hi! Pretend this is a generic paragraph about my interests, hobbies, and associations.
    It should have some CS and systems stuff - use your imagination (or see the about page).
    Thanks!
    </p>
  </section>

  <section class="recent" aria-label="Recent">
    <h2>Recent</h2>
    <MixedFeed limit={10} />
  </section>
</BaseLayout>

<style>
  .hero-name {
    margin: 0 0 var(--space-2);
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: 600;
    line-height: var(--leading-tight);
    color: var(--color-fg);
  }

  .hero-tagline {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
  }

  .intro {
    margin-block: var(--space-8);
    display: flex;
    gap: var(--space-6);
    align-items: center;
  }

  /* Square-crops a rectangular source via object-fit:cover. Tune object-position
     if the head sits too high/low in the circle. */
  .intro__portrait {
    flex-shrink: 0;
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center;
    border: 1px solid var(--color-border);
  }

  .intro p {
    flex: 1;
    max-width: 60ch;
    margin: 0;
    font-size: var(--text-lg);
    line-height: var(--leading-loose);
    color: var(--color-fg);
  }

  @media (max-width: 640px) {
    .intro {
      flex-direction: column;
      align-items: flex-start;
    }
    .intro__portrait {
      width: 96px;
      height: 96px;
    }
  }

  .recent {
    margin-block: var(--space-12);
  }

  .recent h2 {
    margin: 0 0 var(--space-4);
    font-size: var(--text-2xl);
  }
</style>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const all_notes = await getCollection('notes');
const sorted = all_notes.sort(
  (a, b) => b.data.pub_date.getTime() - a.data.pub_date.getTime()
);
const page_title = "Notes";
const description = "Short, often-updated notes — digital-garden style.";
---
<BaseLayout page_title={page_title} description={description} wide>
  <ul class="entry-list">
    {sorted.map((note) => (
      <li>
        <a href={`/notes/${note.id}`}>{note.data.title}</a>
        <span class="entry-list__meta">{note.data.pub_date.toISOString().slice(0, 10)}</span>
      </li>
    ))}
  </ul>
</BaseLayout>
<style>
  .entry-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .entry-list li {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }
  .entry-list__meta {
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
  }
</style>

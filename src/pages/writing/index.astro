---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryList from '../../components/EntryList.astro';

const all_writing = await getCollection('writing');
const items = all_writing
  .sort((a, b) => b.data.pub_date.getTime() - a.data.pub_date.getTime())
  .map((w) => ({
    title: w.data.title,
    date: w.data.pub_date,
    url: `/writing/${w.id}`,
    summary: w.data.summary,
    meta: w.data.venue,
  }));

const page_title = "Writing";
const description = "Writing — articles, essays, and pieces published elsewhere.";
---
<BaseLayout page_title={page_title} description={description} wide>
  <EntryList items={items} />
</BaseLayout>

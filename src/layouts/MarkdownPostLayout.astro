---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;

// timeZone: 'UTC' — pub_date is parsed as midnight UTC by the schema; formatting
// without this rolls back a day in behind-UTC timezones.
const pub_date_label = frontmatter.pub_date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
});
const pub_date_iso = frontmatter.pub_date.toISOString();
---
<BaseLayout
  page_title={frontmatter.title}
  description={frontmatter.description}
  og_type="article"
  og_image={frontmatter.cover?.src}
  pub_date={frontmatter.pub_date}
  author={frontmatter.author}
>
  <p><em>{frontmatter.description}</em></p>
  <p class="post-meta">
    <time datetime={pub_date_iso}>{pub_date_label}</time> · {frontmatter.author}
  </p>

  {frontmatter.cover && (
    <Image
      src={frontmatter.cover}
      alt={frontmatter.cover_alt ?? ''}
      width={600}
      class="post-cover"
    />
  )}

  <ul class="chip-list">
    {frontmatter.tags.map((tag: string) => (
      <li class="chip"><a href={`/tags/${tag}`}>{tag}</a></li>
    ))}
  </ul>

  <slot />
</BaseLayout>
<style>
  .post-meta {
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
  }
  .post-cover {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin-block: var(--space-4);
  }
</style>

---
/**
 * Home-page News list: dated one-liners (awards, positions, milestones),
 * newest first. Backed by the `news` collection (single YAML file).
 * Renders nothing if there are no items.
 */

import { getCollection } from 'astro:content';

const all_news = await getCollection('news');
const sorted = all_news.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const { limit = 6 } = Astro.props;
const recent = sorted.slice(0, limit);

// timeZone: 'UTC' is required — z.coerce.date() parses "2026-05-01" as midnight
// UTC; without this, formatting in a behind-UTC timezone rolls back to the prior day.
const fmt = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' });
---
{recent.length > 0 && (
  <ul class="news">
    {recent.map((item) => (
      <li class="news__item">
        <time class="news__date" datetime={item.data.date.toISOString()}>
          {fmt(item.data.date)}
        </time>
        <span class="news__text">
          {item.data.url
            ? <a href={item.data.url}>{item.data.text}</a>
            : item.data.text}
        </span>
      </li>
    ))}
  </ul>
)}

<style>
  .news {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .news__item {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: var(--space-4);
    align-items: baseline;
  }

  .news__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-fg-muted);
    white-space: nowrap;
  }

  .news__text {
    color: var(--color-fg);
  }

  @media (max-width: 640px) {
    .news__item {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>

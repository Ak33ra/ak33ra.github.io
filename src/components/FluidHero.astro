---
const { variant = 'liquid' } = Astro.props;
---
<section class="fluid-hero">
  <canvas class="fluid-hero__canvas" data-fluid-hero data-variant={variant} aria-hidden="true"></canvas>
  <div class="fluid-hero__static" aria-hidden="true"></div>
  <div class="fluid-hero__content">
    <slot />
  </div>
</section>

<style>
  .fluid-hero {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    height: clamp(360px, 58vh, 600px);
    margin-block: var(--space-8);
    background: var(--color-code-bg);
    isolation: isolate;
  }

  .fluid-hero__canvas,
  .fluid-hero__static {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .fluid-hero__canvas {
    z-index: 1;
  }

  /* Static fallback: shows on no-JS, before canvas inits, and under prefers-reduced-motion. */
  .fluid-hero__static {
    z-index: 0;
    background:
      radial-gradient(80% 80% at 30% 100%, color-mix(in oklab, var(--color-accent) 40%, transparent), transparent 70%),
      radial-gradient(60% 60% at 80% 30%, color-mix(in oklab, var(--color-accent) 20%, transparent), transparent 70%),
      var(--color-bg);
  }

  .fluid-hero__content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-8);
  }

  @media (prefers-reduced-motion: reduce) {
    .fluid-hero__canvas { display: none; }
  }
</style>

<script>
  // Dynamic import keeps the unselected variant out of the bundle.
  // Astro code-splits each `import()` into its own chunk.
  async function boot() {
    const canvases = document.querySelectorAll('canvas[data-fluid-hero]');
    for (const canvas of canvases) {
      const variant = (canvas as HTMLElement).dataset.variant ?? 'liquid';
      if (variant === 'smoke') {
        const { init_fluid_hero_smoke } = await import('../scripts/fluid-hero-smoke.js');
        init_fluid_hero_smoke(canvas as HTMLCanvasElement);
      } else {
        const { init_fluid_hero_liquid } = await import('../scripts/fluid-hero-liquid.js');
        init_fluid_hero_liquid(canvas as HTMLCanvasElement);
      }
    }
  }
  boot();
</script>

---
const year = new Date().getFullYear();
---
<footer>
  <p class="footer-copyright">© {year} Akira van de Groenendaal. All rights reserved.</p>
  <ul class="footer-links">
    <li><a href="https://github.com/Ak33ra">GitHub</a></li>
    {/*
      Add more socials here as plain anchors, e.g.:
        <li><a href="https://www.linkedin.com/in/..." rel="me">LinkedIn</a></li>
        <li><a href="mailto:you@example.com">Email</a></li>
    */}
  </ul>
</footer>

<style>
  footer {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    justify-content: space-between;
    margin-top: var(--space-12);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
  }

  .footer-copyright {
    margin: 0;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-4);
  }

  .footer-links a {
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover,
  .footer-links a:focus-visible {
    color: var(--color-accent);
  }
</style>

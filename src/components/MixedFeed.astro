---
/**
 * Home-page "Recent" feed: fetches all four content collections, interleaves them
 * by date, and renders the top N entries through EntryList (with type labels).
 *
 * Layout/styling lives in EntryList — this component is pure data orchestration.
 */

import { getCollection } from 'astro:content';
import EntryList from './EntryList.astro';

const [blog, projects, notes, writing] = await Promise.all([
  getCollection('blog'),
  getCollection('projects'),
  getCollection('notes'),
  getCollection('writing'),
]);

const items = [
  ...blog.map((p) => ({
    type: 'blog',
    title: p.data.title,
    date: p.data.pub_date,
    url: `/blog/${p.id}`,
    summary: p.data.description,
  })),
  ...projects.map((p) => ({
    type: 'project',
    title: p.data.title,
    date: p.data.end_date ?? p.data.start_date,
    url: `/projects/${p.id}`,
    summary: p.data.summary,
  })),
  ...notes.map((n) => ({
    type: 'note',
    title: n.data.title,
    date: n.data.updated_date ?? n.data.pub_date,
    url: `/notes/${n.id}`,
  })),
  ...writing.map((w) => ({
    type: 'writing',
    title: w.data.title,
    date: w.data.pub_date,
    url: `/writing/${w.id}`,
    summary: w.data.summary ?? `Published in ${w.data.venue}`,
  })),
];

items.sort((a, b) => b.date.getTime() - a.date.getTime());

const { limit = 10 } = Astro.props;
const recent = items.slice(0, limit);
---
<EntryList items={recent} />
